{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InfUsage",
  "version": "0.1.0",
  "identifier": "app.infusage.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InfUsage",
        "width": 320,
        "height": 225,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "backgroundColor": "#f4f4f5"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
